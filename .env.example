# Copia este archivo a .env y rellena tus credenciales del curso.
#   cp .env.example .env   &&   direnv allow
#
# El .env NO se sube al repositorio (está en .gitignore). En Codespaces NO uses
# este archivo: usa los "Codespaces secrets" (Settings → Codespaces → Secrets).

# --- Credenciales AWS (las da el formador / Pronoide) -------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Solo si tus credenciales son temporales (STS):
# AWS_SESSION_TOKEN=

# --- Región de referencia del curso ------------------------------------------
AWS_REGION=eu-west-1
AWS_DEFAULT_REGION=eu-west-1

# --- (Opcional) Asunción de rol ----------------------------------------------
# Si te indican asumir un rol, descomenta y rellena. setup-aws-profiles.sh creará
# un perfil 'lab' que lo asume con las credenciales de arriba.
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/nombre-del-rol
# AWS_ROLE_SESSION_NAME=tf-curso
